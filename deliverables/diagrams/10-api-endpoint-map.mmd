        A2["Email Auth\n━━━━━━━━━━\nPOST /auth/register/email/init\nPOST /auth/register/email/complete\nPOST /auth/login/email/init\nPOST /auth/login/email/complete"]
        A3["Telegram Auth\n━━━━━━━━━━\nPOST /auth/register/telegram/init\nPOST /auth/register/telegram/complete\nPOST /auth/login/telegram/init\nPOST /auth/login/telegram/complete"]
        A4["Shared Auth\n━━━━━━━━━━\nPOST /auth/verify-otp\nPOST /auth/resend-otp\nPOST /auth/refresh\nPOST /auth/logout"]
    end

    subgraph Protected["Protected Endpoints (JWT Required)"]
        PR1["GET /auth/profile\nPOST /auth/profile/link-email/init\nPOST /auth/profile/link-email/verify\nPOST /auth/profile/link-telegram\nPOST /sponsor/code/create"]
    end

