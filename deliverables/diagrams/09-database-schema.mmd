graph TB
    subgraph UserAuth["User and Authentication"]
        User["<b>User</b><br/>id UUID, email, evmAddress<br/>telegramId, status, authMethod<br/>sponsorId FK to User"]
        Session["<b>LoginSession</b><br/>refreshToken, userAgent<br/>ipAddress, expiresAt, revokedAt"]
        Challenge["<b>WalletChallenge</b><br/>address, nonce<br/>message, expiresAt"]
    end

    subgraph AuthFlow["Auth Flow State"]
        Pending["<b>PendingSession</b><br/>type: REGISTER or LOGIN<br/>email, telegramId<br/>verified, expiresAt 30min"]
        OTP["<b>OtpCode</b><br/>code 6-digit, attempts max 5<br/>expiresAt 10min, usedAt"]
    end

    subgraph Referral["Referral System"]
        Sponsor["<b>SponsorCode</b><br/>code BTN-XXXXX<br/>maxUses, usedCount, active"]
    end

    subgraph MigrationSys["Migration System"]
        WalletLink["<b>WalletLink</b><br/>tonAddress, evmAddress<br/>signature, verified"]
        Snapshot["<b>TonSnapshotRow</b><br/>tonAddress, balanceTon<br/>balanceBtn, batchId"]
        Claim["<b>MigrationClaim</b><br/>tonAddress, evmAddress<br/>amountBtn, status, txHash"]
    end

    subgraph Operations["Operations"]
        Job["<b>OperatorJob</b><br/>jobType: DISTRIBUTE etc<br/>payload JSON, status<br/>txHash, retryCount max 3"]
        Audit["<b>AuditLog</b><br/>actor, action, target<br/>detail JSON, txHash"]
    end

    User -->|"has many"| Session
    User -->|"has many"| Sponsor
    User -->|"has many"| WalletLink
    User -->|"has one"| Claim
    User -->|"has many"| Job
    User -->|"sponsors"| User
    Pending -->|"has many"| OTP

    style UserAuth fill:#1e3a5f,stroke:#3b82f6,color:#fff
    style AuthFlow fill:#4a1d6a,stroke:#a855f7,color:#fff
    style Referral fill:#166534,stroke:#22c55e,color:#fff
    style MigrationSys fill:#78350f,stroke:#f59e0b,color:#fff
    style Operations fill:#991b1b,stroke:#ef4444,color:#fff
