        BE9["Audit Logging<br/>All state changes tracked"]
        BE10["Body Size Limit: 1MB<br/>Request ID Tracing"]
    end

    subgraph Frontend["Frontend Security"]
        FE1["No secrets in client<br/>Only public env vars"]
        FE2["Protected Routes<br/>JWT check on navigation"]
        FE3["Wallet Signature<br/>User approves every tx"]
        FE4["Input Validation<br/>Amount limits, formats"]
        FE5["Wrong Network Detection<br/>Chain ID verification"]
    end

    subgraph AccessRoles["Access Control Matrix"]
        R1["DEFAULT_ADMIN_ROLE<br/>━━━━━━━━━━<br/>Contract upgrades<br/>Set addresses<br/>Emergency actions"]
        R2["OPERATOR_ROLE<br/>━━━━━━━━━━<br/>Weekly settlement<br/>Bonus processing<br/>Fund contracts"]
        R3["EMERGENCY_ROLE<br/>━━━━━━━━━━<br/>Pause contracts<br/>Unpause contracts"]
        R4["ADMIN_API_KEY<br/>━━━━━━━━━━<br/>Backend admin routes<br/>Migration management<br/>User management"]
    end

    style SmartContract fill:#1e3a5f,stroke:#3b82f6,color:#fff
    style Backend fill:#4a1d6a,stroke:#a855f7,color:#fff
