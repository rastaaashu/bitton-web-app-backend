        SC1["UUPS Proxy Pattern<br/>Admin-only upgrades"]
        SC2["ReentrancyGuard<br/>On all withdrawals"]
        SC3["SafeERC20<br/>All token transfers"]
        SC4["AccessControl Roles<br/>ADMIN / OPERATOR / EMERGENCY"]
        SC5["Pausable<br/>Emergency shutdown"]
        SC6["Oracle Validation<br/>Staleness < 1hr, Price > 0"]
        SC7["Checks-Effects-Interactions<br/>State before calls"]
        SC8["Storage Gap (50 slots)<br/>Future upgrade safety"]
        SC9["Solidity 0.8.27<br/>Overflow protection"]
    end

    subgraph Backend["Backend API Security"]
        BE1["Helmet Middleware<br/>CSP, HSTS, X-Frame, X-Content"]
        BE2["CORS Whitelist<br/>Only allowed origins"]
        BE3["Rate Limiting<br/>Global: 100/min<br/>Auth: 20/15min<br/>OTP: 5/15min"]
        BE4["JWT Auth (HS256)<br/>15min access + 7d refresh"]
        BE5["Wallet Signature Verify<br/>ethers.verifyMessage()"]
        BE6["Telegram HMAC-SHA256<br/>Bot token verification"]
        BE7["Timing-Safe Comparison<br/>OTP + API Key checks"]
