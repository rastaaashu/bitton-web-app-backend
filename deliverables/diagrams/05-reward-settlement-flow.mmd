flowchart TD
    Start([User or Operator<br/>Triggers Settlement]) --> Check1{Vault Active?}

    Check1 -->|No| Revert1[/"Revert: Vault not active"/]
    Check1 -->|Yes| CalcRewards

    CalcRewards["Calculate Rewards<br/>━━━━━━━━━━<br/>For each active stake:<br/>days x 0.5% x amount x multiplier<br/>━━━━━━━━━━<br/>Short: tier multiplier<br/>(T1=1.0x, T2=1.1x, T3=1.2x)<br/>Long: fixed 1.2x"]

    CalcRewards --> CheckPool{Reward Pool<br/>has enough BTN?}
    CheckPool -->|No| Revert2[/"Revert: Insufficient rewards"/]
    CheckPool -->|Yes| Split

    Split["Split Total Reward<br/>━━━━━━━━━━"]

    Split --> W10["10% → WithdrawalWallet<br/>━━━━━━━━━━<br/>addWithdrawable(user, amount)<br/>Immediately withdrawable"]

    Split --> V90["90% → VestingPool<br/>━━━━━━━━━━<br/>addVesting(user, amount)<br/>Locked, 0.5% daily release"]

    Split --> Matching["Process Matching Bonus<br/>━━━━━━━━━━<br/>Walk up referral chain"]

    Matching --> L1["Level 1 Ancestor<br/>10% of reward"]
    Matching --> L2["Level 2 Ancestor<br/>5% of reward"]
    Matching --> L3["Level 3 Ancestor<br/>3% of reward"]
    Matching --> L4["Level 4-10 Ancestors<br/>1% each (T3 only)"]

    L1 --> QualCheck1{Qualified?<br/>Active Vault +<br/>500 BTN Staked}
    L2 --> QualCheck2{Qualified?}
    L3 --> QualCheck3{Qualified?}
    L4 --> QualCheck4{Qualified?}

    QualCheck1 -->|Yes| BonusPaid1["Bonus added to<br/>ancestor's pending"]
    QualCheck1 -->|No| Skip1["Skip"]
    QualCheck2 -->|Yes| BonusPaid2["Bonus added"]
    QualCheck2 -->|No| Skip2["Skip"]
    QualCheck3 -->|Yes| BonusPaid3["Bonus added"]
    QualCheck3 -->|No| Skip3["Skip"]
    QualCheck4 -->|Yes| BonusPaid4["Bonus added"]
    QualCheck4 -->|No| Skip4["Skip"]

    V90 --> DailyRelease["Daily Vesting Release<br/>━━━━━━━━━━<br/>0.5% of vestedBalance per day<br/>Pro-rated per second<br/>User calls release()"]

    DailyRelease --> ToWW["Released → WithdrawalWallet"]

    W10 --> Withdraw["User Withdraws BTN<br/>━━━━━━━━━━<br/>withdraw(amount)<br/>BTN sent to wallet"]
    ToWW --> Withdraw

    CalcRewards --> ResetTime["Reset lastRewardTime<br/>for all settled stakes"]

    style Start fill:#3b82f6,stroke:#60a5fa,color:#fff
    style Split fill:#a855f7,stroke:#c084fc,color:#fff
    style W10 fill:#166534,stroke:#22c55e,color:#fff
    style V90 fill:#854d0e,stroke:#f59e0b,color:#fff
    style Matching fill:#6b21a8,stroke:#a855f7,color:#fff
    style DailyRelease fill:#854d0e,stroke:#f59e0b,color:#fff
    style Withdraw fill:#15803d,stroke:#4ade80,color:#fff
    style Revert1 fill:#991b1b,stroke:#ef4444,color:#fff
    style Revert2 fill:#991b1b,stroke:#ef4444,color:#fff
    style CalcRewards fill:#1e40af,stroke:#3b82f6,color:#fff
