NODE_ENV=production
PORT=3001

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Blockchain (Base Mainnet)
RPC_URL=https://mainnet.base.org
CHAIN_ID=8453
RELAYER_PRIVATE_KEY=0x_your_relayer_private_key

# Contract addresses (Base Mainnet)
BTN_TOKEN_ADDRESS=0x9c8056dbD494764D6A4B5b2d7b2a3468D28b070f
USDC_TOKEN_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
CUSTODIAL_ADDRESS=0x772D404E45A04DE2D63f5E9b563B531a558309f9
VAULT_MANAGER_ADDRESS=0xd22A5ee59a8c3e9d9Fb21855edC6DA715f40157A
STAKING_VAULT_ADDRESS=0x5B2B0d30A712d36605Bc263c49ec65E73F888bC7
REWARD_ENGINE_ADDRESS=0x4B33b0dF6470B34Dc361D3C3bef2EDdE0cbD99E5
VESTING_POOL_ADDRESS=0x9472756215C25AD6949715908faD0f757DC72Bd9
WITHDRAWAL_WALLET_ADDRESS=0x017088416C4b13A2c1C3FA470fD3Aa16f844BcA2
BONUS_ENGINE_ADDRESS=0x5c9B52D9Eb9EAB450582674F96FC7eD84EC5C6aa
RESERVE_FUND_ADDRESS=0xbdc6e4f9eda0C62228C04ADDfb77bD0164870f7B
TREASURY_ADDRESS=0x9e5d59DBb9e3230d83bf40bD8d30E44bde0Acb4c

# Auth
AUTH_SECRET=generate_a_long_random_string_64_chars_minimum
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
ADMIN_API_KEY=your_admin_api_key

# Email (Resend HTTP API)
EMAIL_API_KEY=re_your_resend_api_key
EMAIL_API_PROVIDER=resend
SMTP_FROM=noreply@bitton.ai

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_BOT_USERNAME=bitton_auth_bot

# App (MUST match your frontend URL for CORS)
APP_URL=https://web-app.bitton.ai
