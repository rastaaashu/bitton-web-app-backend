graph TB
    subgraph Short["SHORT PROGRAM (30 Days)"]
        S1["Lock Period: 30 days"]
        S2["Daily Rate: 0.5%"]
        S3["Multiplier: Tier-based<br/>T1=1.0x / T2=1.1x / T3=1.2x"]
        S4["Early Exit: ALLOWED<br/>15% penalty to Treasury"]
        S5["Example: 1000 BTN @ T3<br/>Daily: 6.0 BTN<br/>Monthly: ~180 BTN"]
    end

    subgraph Long["LONG PROGRAM (180 Days)"]
        L1["Lock Period: 180 days"]
        L2["Daily Rate: 0.5%"]
        L3["Multiplier: Fixed 1.2x<br/>(same for all tiers)"]
        L4["Early Exit: NOT ALLOWED<br/>Reverts if lock not met"]
        L5["Example: 1000 BTN<br/>Daily: 6.0 BTN<br/>6-Month: ~1080 BTN"]
    end

    User((User)) -->|"Choose Program"| Short
    User -->|"Choose Program"| Long

    Short --> Settle["Weekly Settlement<br/>━━━━━━━━━━<br/>10% → Withdrawable<br/>90% → Vesting"]
    Long --> Settle

    Short -->|"Before 30d"| Penalty["Early Exit<br/>-15% Penalty<br/>to Treasury"]
    Short -->|"After 30d"| FullReturn["Full Return<br/>+ Accrued Rewards"]
    Long -->|"After 180d"| FullReturn

    style Short fill:#1e3a5f,stroke:#3b82f6,color:#fff
    style Long fill:#4a1d6a,stroke:#a855f7,color:#fff
    style Settle fill:#166534,stroke:#22c55e,color:#fff
    style Penalty fill:#991b1b,stroke:#ef4444,color:#fff
    style FullReturn fill:#15803d,stroke:#4ade80,color:#fff
    style User fill:#3b82f6,stroke:#60a5fa,color:#fff
