        AD2["System Admin\n━━━━━━━━━━\nGET /admin/status\nGET /admin/jobs\nGET /admin/audit\nGET /admin/users\nGET /admin/users/:id"]
    end

    style Public fill:#166534,stroke:#22c55e,color:#fff
    style AuthEndpoints fill:#854d0e,stroke:#f59e0b,color:#fff
    style Protected fill:#1e40af,stroke:#3b82f6,color:#fff
