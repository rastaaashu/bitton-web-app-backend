NODE_ENV=production
PORT=3001

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Blockchain (Base Mainnet)
RPC_URL=https://mainnet.base.org
CHAIN_ID=8453
RELAYER_PRIVATE_KEY=0x_your_relayer_private_key

# Contract addresses (Base Mainnet)
BTN_TOKEN_ADDRESS=0xc8832f90cfC9bEfB45201f650572e2fFDDf28cfa
USDC_TOKEN_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
CUSTODIAL_ADDRESS=0x798651FBf33cc40D9aecF0257eB6C07aEB7d810C
VAULT_MANAGER_ADDRESS=0x536f1FD032Ea0ceDc1Bb7A9354ac4F1bA70b99bE
STAKING_VAULT_ADDRESS=0x2e28b11425cE8f5E4fbb114E642B65Be2B127888
REWARD_ENGINE_ADDRESS=0x240c868598Cfc474609fe686008F658C9695e1C1
VESTING_POOL_ADDRESS=0xF5aC9a1b52A37d0Ea73671F1174E79c892aD14BC
WITHDRAWAL_WALLET_ADDRESS=0x599BC549601d8A8225b24763898225d2311d64a4
BONUS_ENGINE_ADDRESS=0x0eF5231A860e3722544549a1E0701Cc818DE8046
RESERVE_FUND_ADDRESS=0x74a8D3A1A1167d4d6f8305Cc7cC200E0d51fF853
TREASURY_ADDRESS=0x9e5d59DBb9e3230d83bf40bD8d30E44bde0Acb4c

# Auth
AUTH_SECRET=generate_a_long_random_string_64_chars_minimum
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
ADMIN_API_KEY=your_admin_api_key

# Email (Resend HTTP API)
EMAIL_API_KEY=re_your_resend_api_key
EMAIL_API_PROVIDER=resend
SMTP_FROM=noreply@bitton.ai

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_BOT_USERNAME=bitton_auth_bot

# App (MUST match your frontend URL for CORS)
APP_URL=https://web-app.bitton.ai
