flowchart TD
    Start([User Visits App]) --> HasAccount{Has Account?}

    HasAccount -->|No| Register["Register<br/>━━━━━━━━<br/>Enter Referral Code<br/>+ Accept Disclaimer"]
    HasAccount -->|Yes| Login["Login<br/>━━━━━━━━<br/>Wallet / Email / Telegram"]

    Register --> ConnectWallet["Connect EVM Wallet<br/>+ Sign Message"]
    Login --> ConnectWallet2["Connect EVM Wallet<br/>+ Sign Challenge"]

    ConnectWallet --> Dashboard
    ConnectWallet2 --> Dashboard

    Dashboard["Dashboard<br/>━━━━━━━━━━<br/>View Balances<br/>View Active Stakes<br/>View Pending Rewards"]

    Dashboard --> VaultCheck{Vault Active?}

    VaultCheck -->|No| ActivateVault["Activate Vault<br/>━━━━━━━━━━<br/>Choose Tier:<br/>T1 ($25) / T2 ($50) / T3 ($100)<br/>Pay with USDT or BTN"]
    VaultCheck -->|Yes| StakeFlow

    ActivateVault --> StakeFlow

    StakeFlow["Stake BTN<br/>━━━━━━━━━━<br/>Short (30 days)<br/>or Long (180 days)<br/>Approve + Confirm"]

    StakeFlow --> RewardsAccrue["Rewards Accrue Daily<br/>━━━━━━━━━━<br/>0.5% daily x multiplier"]

    RewardsAccrue --> Settle["Settle Weekly<br/>━━━━━━━━━━<br/>Split rewards:<br/>10% → Withdrawable<br/>90% → Vesting"]

    Settle --> Withdrawable["Withdrawal Wallet<br/>━━━━━━━━━━<br/>10% immediately<br/>available"]
    Settle --> Vesting["Vesting Pool<br/>━━━━━━━━━━<br/>90% locked<br/>0.5% released daily"]

    Vesting -->|"Daily Release"| Withdrawable

    Withdrawable --> Withdraw["Withdraw BTN<br/>━━━━━━━━━━<br/>To personal wallet"]

    StakeFlow --> Unstake["Unstake<br/>━━━━━━━━━━<br/>Short: Early exit OK<br/>(15% penalty)<br/>Long: Must wait 180d"]

    StakeFlow -.->|"Referral triggers"| Bonus["Bonus Engine<br/>━━━━━━━━━━<br/>Direct: 5% of stake<br/>Matching: Level-based"]
    Settle -.->|"Settlement triggers"| Bonus

